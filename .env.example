# ─────────────────────────────────────────────────────────────────────────────
# مقر — Maqar Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
#
# Convention:
#   NEXT_PUBLIC_*   → exposed to the browser (safe to expose)
#   Everything else → server-side only (NEVER use in client components)
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────
# Your app's canonical URL. Used for SEO (sitemap, canonical, OG tags).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment name. Controls PWA service worker registration.
# Use "development" locally (disables SW), "production" on Vercel.
NEXT_PUBLIC_APP_ENV=development

# Mock data fallback guard (search page).
# When Supabase is configured but returns 0 approved listings, this flag controls
# whether the search page falls back to local mock data (for QA/staging) or shows
# the true empty state (for production).
#
#   true  → staging / dev: empty Supabase → show filtered mock listings (safe for QA)
#   false → production: empty Supabase → show real empty state (never show mock data)
#
# ⚠️  Always set to false before public launch. Default is false if omitted.
NEXT_PUBLIC_ALLOW_MOCK_FALLBACK=true


# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
# See: docs/SUPABASE_SETUP.md

# Your Supabase project URL (safe to expose — includes project ref)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key — enforces RLS, safe to expose in client code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — BYPASSES RLS, server-side ONLY.
# NEVER expose in client code or NEXT_PUBLIC_ variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: direct DB URL for Prisma/migrations (if using Prisma alongside Supabase)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres


# ── Storage ───────────────────────────────────────────────────────────────────
# Supabase Storage bucket names (must match buckets you create in the dashboard)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=listing-images


# ── AI / Anthropic ────────────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
# IMPORTANT: Server-side ONLY — never use NEXT_PUBLIC_ prefix.
# See: docs/AI_SETUP.md
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI provider (only "anthropic" currently supported)
AI_PROVIDER=anthropic

# Claude model to use. Haiku is fast & cheap; switch to Sonnet for higher quality.
AI_MODEL=claude-3-5-haiku-20241022

# Daily AI usage limits per plan (enforced server-side)
AI_DAILY_FREE_LIMIT=5
AI_AGENT_PRO_LIMIT=50
AI_AGENCY_LIMIT=200


# ── Payments ─────────────────────────────────────────────────────────────────
# "mock"    → no real payment processing (default for development)
# "thawani" → Thawani Pay (recommended for Oman, supports OMR)
# "stripe"  → Stripe (international fallback)
# See: docs/PAYMENTS_SETUP.md
PAYMENT_PROVIDER=mock

# Client-side payment mode indicator (controls UI only — never controls access)
NEXT_PUBLIC_PAYMENT_MODE=mock

# Stripe (server-side only — fill when PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Thawani Pay (server-side only — fill when PAYMENT_PROVIDER=thawani)
# THAWANI_API_KEY=
# NEXT_PUBLIC_THAWANI_PUBLISHABLE_KEY=
# THAWANI_WEBHOOK_SECRET=
# THAWANI_ENV=sandbox

# Redirect URLs after payment (update domain for production)
PAYMENT_SUCCESS_URL=http://localhost:3000/account/billing?success=1
PAYMENT_CANCEL_URL=http://localhost:3000/pricing?cancelled=1


# ── SMS / OTP ─────────────────────────────────────────────────────────────────
# Supabase handles OTP natively. Configure your SMS provider in the Supabase dashboard.
# Optional: override with direct Twilio if needed.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1234567890


# ── PWA / Push Notifications ─────────────────────────────────────────────────
# VAPID keys for Web Push notifications.
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=   ← server-side only


# ── Analytics ─────────────────────────────────────────────────────────────────
# PostHog for user behavior analytics (optional)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry for error monitoring (optional)
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...


# ── Map Provider ─────────────────────────────────────────────────────────────
# Mapbox GL JS token for the property map feature
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiLi4uIn0...

# Alternative: Google Maps
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...


# ── Service Worker Cache ─────────────────────────────────────────────────────
# No env vars needed — controlled via public/sw.js directly.
# Bump the CACHE_NAME version string in sw.js on breaking cache changes.
# Current CACHE_NAME: "maqar-v1"
#
# NEVER_CACHE_PATTERNS (configured in sw.js):
#   /api/auth/*, /api/payment/*, /api/admin/*
