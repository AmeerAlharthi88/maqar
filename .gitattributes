# Normalize line endings to LF in the repository;
# git checks out with CRLF on Windows automatically via core.autocrlf.
* text=auto eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.lock text eol=lf
